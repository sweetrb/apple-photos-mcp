node_modules/

# Build output is intentionally tracked so the marketplace plugin works
# without an npm install step (Claude Code does not run npm install on
# path-source plugins). Override the global ~/.gitignore entry.
# Only the bundled entrypoint is tracked; per-module tsc output (e.g. from
# `npm run dev`) stays ignored.
!build/
build/*
!build/index.js

*.js.map
*.d.ts.map
.env
.DS_Store
coverage/

# Python venv
venv/
__pycache__/

# Vitest temp files
vitest.config.ts.timestamp-*

# npm package files
*.tgz
.claude/
.worktrees/
